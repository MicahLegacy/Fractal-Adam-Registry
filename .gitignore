# Large or mutable data artifacts
/data/raw/*
!/data/raw/.gitkeep
!/data/raw/README.md

/data/external/*
!/data/external/.gitkeep
!/data/external/README.md

/data/interim/*
!/data/interim/.gitkeep
!/data/interim/README.md

/data/processed/*
!/data/processed/.gitkeep
!/data/processed/README.md

# Run logs
/results/logs/*
!/results/logs/.gitkeep
!/results/logs/README.md
